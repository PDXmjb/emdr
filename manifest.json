{
  "manifest_version": 2,
  "name": "EMDR Circle",
  "version": "1.0",
  "description": "Animated circle for EMDR therapy",
  "permissions": ["activeTab", "storage"],
  "browser_action": {
    "default_title": "EMDR Circle",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
